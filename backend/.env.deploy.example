# FTP Deployment Credentials
# Copy this file to .env.deploy and fill in your values
# NEVER commit .env.deploy to git!

# OVH example (check your OVH manager for exact values)
FTP_HOST=ftp.cluster0XX.hosting.ovh.net
FTP_USER=yourlogin
FTP_PASS=your-ftp-password

# Remote path - typically /www or /public_html on OVH
FTP_PATH=/www
